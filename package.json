{
  "name": "line-oss-crm",
  "version": "0.15.0",
  "private": true,
  "description": "Open-source LINE Official Account CRM/marketing automation",
  "scripts": {
    "dev:worker": "pnpm --filter worker dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "sandbox:create-line-harness": "bash scripts/run-create-line-harness-sandbox.sh",
    "deploy:worker": "pnpm --filter worker deploy",
    "deploy:web": "pnpm --filter web build",
    "db:migrate": "wrangler d1 execute line-crm --file=packages/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute line-crm --file=packages/db/schema.sql --local",
    "deploy:setup": "node packages/create-line-harness/dist/index.js",
    "deploy:update": "node packages/create-line-harness/dist/index.js update",
    "tacteq:activate-inquiry-form": "tsx scripts/tacteq/activate-inquiry-form.ts",
    "tacteq:activate-form-notification": "tsx scripts/tacteq/activate-form-notification.ts",
    "tacteq:activate-notion-backup": "tsx scripts/tacteq/activate-notion-backup.ts",
    "tacteq:backfill-notion": "tsx scripts/tacteq/backfill-notion-submissions.ts",
    "tacteq:activate-welcome": "tsx scripts/tacteq/activate-welcome.ts",
    "tacteq:upload-welcome-image": "tsx scripts/tacteq/upload-welcome-image.ts",
    "tacteq:sync-followers": "tsx scripts/tacteq/sync-followers.ts --token-from-d1",
    "tacteq:import-chat": "tsx scripts/tacteq/import-chat-history.ts",
    "tacteq:setup-pipeline-tags": "tsx scripts/tacteq/setup-pipeline-tags.ts",
    "tacteq:clear-unanswered": "tsx scripts/tacteq/clear-unanswered-inbox.ts",
    "test:scripts": "vitest run --config vitest.config.ts",
    "build:bundle": "tsx scripts/release/build-bundle.ts"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0",
    "wrangler": "4"
  }
}
